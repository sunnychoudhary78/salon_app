<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow HTTP to LAN/dev backend; tighten before Play Store production -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
